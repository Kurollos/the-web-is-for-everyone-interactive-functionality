
 <main class="categoriepagina">
  <section class="container">

    <section class="product-grid">
      {% for product in products %}
        <article class="product-card">
          <section class="product-image">
            <img src="{{ product.img | default: product.image }}" alt="{{ product.name }}">
          </section>
          <section class="product-info">
            <h2>{{ product.name }}</h2>
            <p class="prijs">€{{ product.amount }}</p>
            <p class="shop">
              Shop:
              <a href="{{ product.shop_url }}" target="_blank">{{ product.shop_name }}</a>
            </p>
            <p class="spotter">
              Spotter:
              {% if product.spotter_img %}
                <img src="{{ product.spotter_img }}" alt="{{ product.spotter }}">
              {% endif %}
              {{ product.spotter }}
            </p>
            <a href="/product/{{ product.slug }}" class="button">Bekijk product</a>
          </section>
        </article>
      {% endfor %}
    </section>

</main>

<footer>
  <h3>Milledoni</h3>
  <p>Unieke cadeaus voor speciale momenten.</p>

  <h3>Contact</h3>
  <p>Email: info@milledoni.nl</p>

  <h3>Volg ons</h3>
  <p>
    <a href="#">Instagram</a> |
    <a href="#">Facebook</a> |
    <a href="#">TikTok</a>
  </p>

  <p>© 2026 Milledoni. Alle rechten voorbehouden.</p>
</footer>