<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Milledoni Cadeaus</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <!-- =====================
       Header
  ===================== -->
  <header class="site-header">
    <section class="container">
      <a href="/" class="logo">
        <img src="{{ 'milledoni.png' | assets_url }}" alt="Milledoni">
      </a>      
      <nav class="main-nav">
        <ul>
          <li><a href="/cadeaus">Cadeaus</a></li>
          <li><a href="/categorieën">Categorieën</a></li>
          <li><a href="/wishlist">Wishlist</a></li>
        </ul>
      </nav>
    </section>
  </header>

  <!-- =====================
       Main content
  ===================== -->
  <main class="categoriepagina">
    <section class="container">

      <!-- Sidebar links -->
      <div class="sidebar">

        <!-- Chatbot -->
        <section class="chatbot">
          <section class="chat-window">
            <p class="message bot">Hallo! Waar kan ik je mee helpen?</p>
            <p class="message user">Ik heb een vraag.</p>
          </section>

          <section class="chat-input">
            <form>
              <input type="text" placeholder="Ik ben op zoek naar een cadeau voor..." />
              <button type="submit"><img src="assets/sendicon.svg" alt="Verstuur bericht"></button>
            </form>
          </section>
        </section>

        <!-- Search en filters -->
        <section class="search-bar-sidebar">
          <form action="/" method="get">

            <section class="filter-card">
              <h2>Price range (€)</h2>
              <button type="submit" name="price" value="10">Under €10</button>
              <button type="submit" name="price" value="25">Under €25</button>
              <button type="submit" name="price" value="50">Under €50</button>
            </section>

            <section class="filter-card">
              <h2>Have vs Do</h2>
              <button type="submit" name="type" value="have">Have</button>
              <button type="submit" name="type" value="do">Do</button>
            </section>

            <section class="filter-card">
              <h2>Traditional vs Experimental</h2>
              <button type="submit" name="style" value="traditional">Traditional</button>
              <button type="submit" name="style" value="experimental">Experimental</button>
            </section>

          </form>
        </section>

      </div>

  <!-- Producten rechts -->
<section class="product-grid">
  {% for product in products %}
    <article class="product-card">
      <section class="product-image">
        <img src="{{ product.img | default: product.image }}" alt="{{ product.name }}">
      </section>

     <!-- Thumbs-up knop direct onder de Bekijk product knop -->
        <form action="/like" method="POST">
        <input type="hidden" name="user_id" value="1">
        <input type="hidden" name="product_id" value="{{ product.id }}">
        <button type="submit">👍 Like</button>
        </form>

        

      <section class="product-info">
        <h2>{{ product.name }}</h2>
        <p class="prijs">€{{ product.amount }}</p>
        <p class="shop">
          Shop: <a href="{{ product.shop_url }}" target="_blank">{{ product.shop_name }}</a>
        </p>
        <p class="spotter">
          Spotter:
          {% if product.spotter_img %}
            <img src="{{ product.spotter_img }}" alt="{{ product.spotter }}">
          {% endif %}
          {{ product.spotter }}
        </p>

        <!-- Bekijk product knop -->
        <a href="/product/{{ product.slug }}" class="button">Bekijk product</a>


      </section>
    </article>
  {% endfor %}
</section>
      
    </section>
  </main>

  <!-- =====================
       Footer
  ===================== -->
  <footer>
    <h3>Milledoni</h3>
    <p>Unieke cadeaus voor speciale momenten.</p>

    <h3>Contact</h3>
    <p>Email: info@milledoni.nl</p>

    <h3>Volg ons</h3>
    <p>
      <a href="#">Instagram</a> |
      <a href="#">Facebook</a> |
      <a href="#">TikTok</a>
    </p>

    <p>© 2026 Milledoni. Alle rechten voorbehouden.</p>
  </footer>

</body>
</html>